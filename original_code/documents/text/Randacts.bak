function acts=randacts(ants,NActions,WorldSize,NEnergyStates,state);

% RANDACTS Create a vector of random, legal actions.
%
%          USAGE:  acts=randacts(ants,NActions,WorldSize,state);

energy=floor(state/100);
direction=rem(floor(state/10),10);
onfood=rem(state,10);

for k=1:length(state),
  allowed=ones(1,NActions);
  if (energy(k)==1),
    % not enough energy left to procreate or communicate.
    allowed(3)=0;
    allowed(2)=0;
  end
  if ((onfood(k)==1)|(round(ants(3,k))==NEnergyStates)),
    % no food here, or we have a "full tank," so we can't eat.
    allowed(1)=0;
  end
  if ((direction(k)==1)&(ants(1,k)==1)),
    allowed(5)=0;
  end
  if ((direction(k)==2)&(ants(2,k)==1)),
    allowed(6)=0;
  end
  if ((direction(k)==3)&(ants(1,k)==WorldSize)),
    allowed(7)=0;
  end
  if ((direction(k)==4)&(ants(2,k)==WorldSize)),
    allowed(8)=0;
  end
  allowed=find(allowed);
  acts(k)=allowed(floor(length(allowed)*rand(1))+1);
end

